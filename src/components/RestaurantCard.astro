---
import { cuisineToSlug, moodToSlug } from '../lib/slugify';

interface Props {
  entry: {
    id: string;
    data: {
      name: string;
      cuisine: string;
      price: string;
      address: string;
      pick?: boolean;
      image?: string;
      moods?: string[];
      dishes?: string[];
      summary?: string;
    };
  };
}

const { entry } = Astro.props;
const { id, data } = entry;
const cuisineSlug = cuisineToSlug(data.cuisine);
---

<article class="r-card">
  {data.image && (
    <div class="r-card-img">
      <img src={data.image} alt={data.name} loading="lazy" />
    </div>
  )}
  <div class="r-card-body">
    <div class="r-card-meta">
      <a href={`/cuisine/${cuisineSlug}`} class="cuisine-link">{data.cuisine}</a>
      <span class="dot" aria-hidden="true">·</span>
      <span>{data.price}</span>
    </div>
    <div class="r-card-name">
      <a href={`/restaurants/${id}`} class="card-link">{data.name}</a>
    </div>
    <div class="r-card-addr">{data.address}</div>
    {data.summary && <p class="r-card-desc">{data.summary}</p>}
    {data.moods && data.moods.length > 0 && (
      <div class="mood-badges" role="list" aria-label="Good for">
        {data.moods.map(mood => (
          <a href={`/mood/${moodToSlug(mood)}`} class="mood-badge" data-mood={moodToSlug(mood)} role="listitem">{mood}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .r-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--ink);
    transition: background 0.2s ease, color 0.2s ease;
    position: relative;
    cursor: pointer;
  }

  .r-card:hover { background: var(--hover-bg); color: var(--hover-ink); }

  .r-card:hover .r-card-meta,
  .r-card:hover .r-card-addr,
  .r-card:hover .r-card-desc,
  .r-card:hover .cuisine-link,
  .r-card:hover .dot {
    color: var(--hover-ink);
    transition: color 0.2s ease;
  }

  .r-card-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .r-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .r-card:hover .r-card-img img { transform: scale(1.03); }

  .r-card-body {
    padding: 1.25rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .r-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    margin-bottom: 0.2rem;
    position: relative;
    z-index: 1;
  }

  .cuisine-link {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cuisine-link:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .dot { color: var(--rule-dark); }

  .r-card-name {
    font-family: var(--serif);
    font-size: clamp(var(--step-2), 2vw, var(--step-3));
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  /* Restaurant name link covers the whole card via ::after overlay */
  .card-link {
    color: inherit;
    text-decoration: none;
  }

  .card-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .r-card-addr {
    font-family: var(--mono);
    font-size: var(--step--1);
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }

  .r-card-desc {
    font-family: var(--sans);
    font-size: var(--step-0);
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.65;
    margin-top: 0.4rem;
  }

  /* ── Mood badges ── */
  .mood-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.6rem;
    position: relative;
    z-index: 1;
  }

  .mood-badge {
    font-family: var(--mono);
    font-size: var(--step--1);
    font-weight: 400;
    color: var(--ink-mid);
    background: var(--surface);
    border: 1px solid var(--rule-dark);
    border-radius: 100px;
    padding: 0.18rem 0.55rem;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    letter-spacing: 0.02em;
  }

  .mood-badge:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--bg);
  }

</style>
