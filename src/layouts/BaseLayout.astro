---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — MCR Eats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Libre+Franklin:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="site-wrap">

    <header class="masthead">
      <p class="masthead-kicker">A Manchester neighbourhood restaurant guide</p>
      <a href="/" class="masthead-wordmark">MCR <em>Eats</em></a>
    </header>

    <nav class="nav-strip">
      <a href="/">Home</a>
      <a href="/northern-quarter">Northern Quarter</a>
      <a href="/ancoats">Ancoats</a>
      <a href="/chorlton">Chorlton</a>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-brand"><em>MCR Eats</em></p>
        <p class="footer-meta">A personal guide · Not sponsored · Opinions entirely our own · Manchester, England</p>
      </div>
    </footer>

  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --surface: #f8f6f3;
    --rule: #dedad3;
    --rule-dark: #b5b0a8;
    --ink: #0f0f0d;
    --ink-mid: #3a3835;
    --ink-muted: #7c7870;
    --accent: #c8401a;

    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Libre Franklin', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 400;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Site column ── */
  .site-wrap {
    max-width: 1240px;
    margin: 0 auto;
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  /* ── Masthead ── */
  .masthead {
    text-align: center;
    padding: 2.5rem 2rem 2rem;
    border-bottom: 2px solid var(--ink);
  }

  .masthead-kicker {
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }

  .masthead-wordmark {
    display: block;
    font-family: var(--serif);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    text-decoration: none;
    color: var(--ink);
  }

  .masthead-wordmark em {
    font-style: italic;
    color: var(--accent);
  }

  /* ── Nav ── */
  .nav-strip {
    border-bottom: 1px solid var(--rule);
    padding: 0.8rem 2rem;
    display: flex;
    justify-content: center;
    gap: 3rem;
    overflow-x: auto;
  }

  .nav-strip a {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .nav-strip a:hover { color: var(--ink); }

  /* ── Footer ── */
  .footer {
    border-top: 2px solid var(--ink);
    padding: 1.5rem 2rem;
    margin-top: 5rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-brand {
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink);
  }

  .footer-meta {
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 400;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }
</style>
