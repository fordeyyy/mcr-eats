---
import { MOODS } from '../lib/moods';
import { NEIGHBOURHOODS } from '../lib/neighbourhoods';

const { title } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — MCR Eats</title>
  <link rel="stylesheet" href="https://use.typekit.net/oat5ofj.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <slot name="head" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <div class="site-wrap">

    <header class="masthead">
      <div class="masthead-inner">
        <p class="masthead-kicker">A Manchester neighbourhood restaurant guide</p>
        <a href="/" class="masthead-logo" aria-label="MCR Eats — Home">
          <svg viewBox="0 0 280 192" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <defs>
              <clipPath id="bee-abdomen">
                <ellipse cx="140" cy="110" rx="13" ry="21"/>
              </clipPath>
            </defs>

            <!-- Knife -->
            <path d="M 40,136 L 41.5,54 Q 43.5,34 45.5,54 L 46,136 Z" fill="var(--ink)"/>
            <rect x="38" y="136" width="10" height="7" rx="1.5" fill="var(--ink)"/>
            <rect x="39.5" y="144" width="7" height="28" rx="3.5" fill="var(--ink)"/>

            <!-- Hexagon -->
            <polygon points="140,27 199,61 199,130 140,164 81,130 81,61"
              fill="none" stroke="var(--ink)" stroke-width="2" stroke-linejoin="miter"/>

            <!-- Upper wings -->
            <ellipse cx="120" cy="79" rx="18" ry="7.5"
              fill="var(--surface)" stroke="var(--ink)" stroke-width="1.5"
              transform="rotate(-35 120 79)"/>
            <ellipse cx="160" cy="79" rx="18" ry="7.5"
              fill="var(--surface)" stroke="var(--ink)" stroke-width="1.5"
              transform="rotate(35 160 79)"/>

            <!-- Lower wings -->
            <ellipse cx="124" cy="97" rx="13" ry="5.5"
              fill="var(--surface)" stroke="var(--ink)" stroke-width="1.5"
              transform="rotate(-20 124 97)"/>
            <ellipse cx="156" cy="97" rx="13" ry="5.5"
              fill="var(--surface)" stroke="var(--ink)" stroke-width="1.5"
              transform="rotate(20 156 97)"/>

            <!-- Abdomen -->
            <ellipse cx="140" cy="110" rx="13" ry="21" fill="var(--ink)"/>
            <rect x="127" y="98"  width="26" height="5" clip-path="url(#bee-abdomen)" fill="var(--accent)"/>
            <rect x="127" y="110" width="26" height="5" clip-path="url(#bee-abdomen)" fill="var(--accent)"/>
            <rect x="127" y="122" width="26" height="4" clip-path="url(#bee-abdomen)" fill="var(--accent)"/>

            <!-- Stinger -->
            <polygon points="137,130 143,130 140,140" fill="var(--ink)"/>

            <!-- Thorax -->
            <ellipse cx="140" cy="85" rx="10" ry="9" fill="var(--ink)"/>

            <!-- Head -->
            <circle cx="140" cy="70" r="8" fill="var(--ink)"/>
            <circle cx="136.5" cy="68" r="1.8" fill="var(--bg)"/>
            <circle cx="143.5" cy="68" r="1.8" fill="var(--bg)"/>

            <!-- Antennae -->
            <line x1="137" y1="63" x2="128" y2="49" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="127" cy="48" r="2.5" fill="var(--ink)"/>
            <line x1="143" y1="63" x2="152" y2="49" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="153" cy="48" r="2.5" fill="var(--ink)"/>

            <!-- Spoon -->
            <ellipse cx="237" cy="55" rx="11" ry="20" fill="var(--ink)"/>
            <rect x="234.5" y="75" width="5" height="97" rx="2.5" fill="var(--ink)"/>
          </svg>
        </a>
      </div>
    </header>

    <nav class="nav-strip">
      <div class="nav-inner">
        <a href="/" class={`nav-home${currentPath === '' ? ' active' : ''}`}>Home</a>

        <div class="nav-dropdown">
          <span class="nav-trigger">Neighbourhoods ↓</span>
          <div class="nav-menu">
            <div class="nav-menu-inner">
              {NEIGHBOURHOODS.map(n => (
                <a href={`/${n.slug}`} class={currentPath === `/${n.slug}` ? 'active' : ''}>{n.label}</a>
              ))}
            </div>
          </div>
        </div>

        <div class="nav-dropdown">
          <span class="nav-trigger">Mood ↓</span>
          <div class="nav-menu">
            <div class="nav-menu-inner">
              {MOODS.map(m => (
                <a href={`/mood/${m.slug}`} class={currentPath === `/mood/${m.slug}` ? 'active' : ''}>{m.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <div class="main-inner">
        <slot />
      </div>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-brand"><em>MCR Eats</em></p>
        <p class="footer-meta">A personal guide · Not sponsored · Opinions entirely our own · Manchester, England</p>
      </div>
    </footer>

  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #fdf8ec;
    --surface: #f5ecda;
    --rule: #e5d4b0;
    --rule-dark: #c8a870;
    --ink: #281c0a;
    --ink-mid: #4e3318;
    --ink-muted: #896840;
    --accent: #C8A000;
    --hover-bg: #e8c230;
    --hover-ink: #1a0800;

    /* ── Type scale (Major Third ×1.25) ── */
    --step--1: 0.64rem;
    --step-0:  0.8rem;
    --step-1:  1rem;
    --step-2:  1.25rem;
    --step-3:  1.563rem;
    --step-5:  2.441rem;
    --step-6:  3.052rem;

    --serif: 'early-sans-variable', system-ui, sans-serif;
    --sans: 'late-serif-variable', Georgia, serif;
    --mono: 'letter-gothic-recast', 'DM Mono', 'Courier New', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 400;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Site column ── */
  .site-wrap {
    max-width: 1240px;
    margin: 0 auto;
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  .main-inner {
    max-width: 1240px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Masthead ── */
  .masthead {
    border-bottom: 2px solid var(--ink);
  }

  .masthead-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
  }

  .masthead-kicker {
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }

  .masthead-logo {
    display: block;
    width: clamp(120px, 18vw, 190px);
    margin: 0.75rem auto 0;
    color: var(--ink);
    text-decoration: none;
  }

  .masthead-logo svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Nav ── */
  .nav-strip {
    border-bottom: 1px solid var(--rule);
  }

  .nav-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .nav-home,
  .nav-trigger {
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
    display: flex;
    align-items: center;
    padding: 0.85rem 1.25rem;
  }

  .nav-home:first-child { padding-left: 0; }
  .nav-home:hover { color: var(--ink); }
  .nav-home.active { color: var(--ink); }

  /* ── Shared dropdown ── */
  .nav-dropdown {
    position: relative;
    flex-shrink: 0;
    margin-left: auto;
  }

  .nav-dropdown + .nav-dropdown { margin-left: 0; }

  .nav-trigger {
    cursor: default;
    user-select: none;
  }

  .nav-dropdown:hover .nav-trigger { color: var(--ink); }

  .nav-menu {
    display: none;
    position: absolute;
    right: 0;
    top: 100%;
    padding-top: 0.6rem;
    min-width: 190px;
    z-index: 100;
  }

  .nav-dropdown:hover .nav-menu { display: block; }

  .nav-menu-inner {
    background: var(--bg);
    border: 1px solid var(--rule);
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
  }

  .nav-menu a {
    display: block;
    font-family: var(--serif);
    font-size: var(--step-0);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--rule);
    transition: color 0.15s, background 0.15s;
  }

  .nav-menu a:last-child { border-bottom: none; }
  .nav-menu a:hover { color: var(--ink); background: var(--surface); }
  .nav-menu a.active { color: var(--accent); }

  /* ── Footer ── */
  .footer {
    border-top: 2px solid var(--ink);
    margin-top: 5rem;
  }

  .footer-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-brand {
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink);
  }

  .footer-meta {
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 400;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }
</style>
