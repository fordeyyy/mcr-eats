---
import BaseLayout from '../layouts/BaseLayout.astro';
import RestaurantCard from '../components/RestaurantCard.astro';
import { getCollection } from 'astro:content';
import { NEIGHBOURHOODS } from '../lib/neighbourhoods';

export async function getStaticPaths() {
  const allRestaurants = await getCollection('restaurants');
  const allNeighbourhoods = await getCollection('neighbourhoods');

  return NEIGHBOURHOODS.map(n => {
    const content = allNeighbourhoods.find(c => c.data.slug === n.slug);
    return {
      params: { neighbourhood: n.slug },
      props: {
        label: content?.data.label ?? n.label,
        strapline: content?.data.strapline ?? '',
        pullQuote: content?.data.pullQuote ?? '',
        restaurants: allRestaurants
          .filter(r => r.data.neighbourhood === n.slug)
          .sort((a, b) => (b.data.pick ? 1 : 0) - (a.data.pick ? 1 : 0)),
      },
    };
  });
}

const { label, strapline, pullQuote, restaurants } = Astro.props;
---

<BaseLayout title={label} description={strapline}>

  <div class="page-header">
    <h1 class="page-title">{label}</h1>
    {strapline && <p class="page-strapline">{strapline}</p>}
  </div>

  {pullQuote && (
    <div class="pull-quote">
      <p>{pullQuote}</p>
    </div>
  )}

  <div class="r-grid">
    {restaurants.length > 0
      ? restaurants.map(entry => <RestaurantCard entry={entry} />)
      : <p class="empty">No listings yet — check back soon.</p>
    }
  </div>

</BaseLayout>

<style>
  .page-header {
    padding: 3rem 3rem 2.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .page-title {
    font-family: var(--serif);
    font-size: clamp(var(--step-5), 6vw, var(--step-6));
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .page-strapline {
    font-family: var(--serif);
    font-size: var(--step-1);
    font-weight: 300;
    color: var(--ink-muted);
    max-width: 56ch;
    line-height: 1.6;
  }

  .pull-quote {
    padding: 2rem 3rem;
    border-bottom: 1px solid var(--rule);
  }

  .pull-quote p {
    font-family: var(--sans);
    font-size: clamp(var(--step-2), 2.5vw, var(--step-3));
    font-style: italic;
    color: var(--ink-mid);
    line-height: 1.55;
    max-width: 72ch;
  }

  .r-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .empty {
    grid-column: 1 / -1;
    padding: 3rem;
    font-family: var(--sans);
    font-size: var(--step-1);
    color: var(--ink-muted);
    background: var(--bg);
  }

  @media (max-width: 768px) {
    .r-grid { grid-template-columns: repeat(2, 1fr); }
    .page-header, .pull-quote { padding-left: 1.5rem; padding-right: 1.5rem; }
  }

  @media (max-width: 480px) {
    .r-grid { grid-template-columns: 1fr; }
  }
</style>
