---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RestaurantCard from '../../components/RestaurantCard.astro';
import { getCollection } from 'astro:content';
import { MOODS } from '../../lib/moods';

export async function getStaticPaths() {
  const allRestaurants = await getCollection('restaurants');

  return MOODS.map(m => ({
    params: { mood: m.slug },
    props: {
      mood: m.label,
      restaurants: allRestaurants
        .filter(r => r.data.moods?.includes(m.label))
        .sort((a, b) => (b.data.pick ? 1 : 0) - (a.data.pick ? 1 : 0)),
    },
  }));
}

const { mood, restaurants } = Astro.props;
---

<BaseLayout title={mood}>

  <div class="page-header">
    <span class="page-eyebrow">Good for</span>
    <h1 class="page-title">{mood}</h1>
    <p class="page-strapline">{restaurants.length} {restaurants.length === 1 ? 'restaurant' : 'restaurants'} in the guide</p>
  </div>

  <div class="r-grid">
    {restaurants.map(entry => <RestaurantCard entry={entry} />)}
  </div>

</BaseLayout>

<style>
  .page-header {
    padding: 3rem 3rem 2.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .page-eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-family: var(--serif);
    font-size: clamp(var(--step-5), 6vw, var(--step-6));
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .page-strapline {
    font-family: var(--serif);
    font-size: var(--step-1);
    font-weight: 300;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .r-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  @media (max-width: 768px) {
    .r-grid { grid-template-columns: repeat(2, 1fr); }
    .page-header { padding-left: 1.5rem; padding-right: 1.5rem; }
  }

  @media (max-width: 480px) {
    .r-grid { grid-template-columns: 1fr; }
  }
</style>
