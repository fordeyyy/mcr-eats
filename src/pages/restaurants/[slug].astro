---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { cuisineToSlug } from '../../lib/slugify';
import { NEIGHBOURHOODS } from '../../lib/neighbourhoods';

export async function getStaticPaths() {
  const restaurants = await getCollection('restaurants');
  return restaurants.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const r = entry.data;

const neighbourhood = NEIGHBOURHOODS.find(n => n.slug === r.neighbourhood);
const neighbourhoodLabel = neighbourhood?.label ?? r.neighbourhood;

const ALL_DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const DAY_SHORT: Record<string, string> = {
  Monday: 'Mon', Tuesday: 'Tue', Wednesday: 'Wed', Thursday: 'Thu',
  Friday: 'Fri', Saturday: 'Sat', Sunday: 'Sun',
};
const openSet = new Set(r.openDays ?? []);
const mapQuery = encodeURIComponent(`${r.name} ${r.address}`);
---

<BaseLayout title={r.name}>

  <div class="detail-wrap">

    <div class="detail-header">

      <div class="back">
        <a href={`/${r.neighbourhood}`}>← {neighbourhoodLabel}</a>
      </div>

      <div class="detail-meta">
        <a href={`/cuisine/${cuisineToSlug(r.cuisine)}`} class="cuisine-link">{r.cuisine}</a>
        <span class="dot" aria-hidden="true">·</span>
        <span>{r.price}</span>
        </div>

      <h1 class="detail-name">{r.name}</h1>
      <p class="detail-address">{r.address}</p>

      {r.image && (
        <div class="photo-wrap">
          <img src={r.image} alt={r.name} />
        </div>
      )}

    </div>

    <div class="detail-body">

      <div class="detail-main">

        <div class="detail-rule"></div>

        <p class="detail-desc">{entry.body}</p>

        {r.dishes && r.dishes.length > 0 && (
          <>
            <div class="detail-rule"></div>
            <div class="top-dishes">
              <span class="top-dishes-label">Top dishes</span>
              <ul class="top-dishes-list">
                {r.dishes.slice(0, 3).map(dish => <li>{dish}</li>)}
              </ul>
            </div>
          </>
        )}

        <div class="detail-rule"></div>

        <div class="detail-links">
          {r.website && (
            <a href={r.website} target="_blank" rel="noopener" class="link-primary">
              Visit website →
            </a>
          )}
          {r.mapsUrl && (
            <a href={r.mapsUrl} target="_blank" rel="noopener" class="link-secondary">
              View on map →
            </a>
          )}
        </div>

      </div>

      <aside class="detail-sidebar">

        <div class="sidebar-map">
          <iframe
            src={`https://maps.google.com/maps?q=${mapQuery}&output=embed&z=16`}
            width="100%"
            height="180"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

        {r.openDays && r.openDays.length > 0 && (
          <>
          <span class="sidebar-label">Open</span>
          <ul class="days-list">
            {ALL_DAYS.map(day => (
              <li class={openSet.has(day) ? 'day day--open' : 'day day--closed'}>
                <span class="day-short">{DAY_SHORT[day]}</span>
                <span class="day-full">{day}</span>
              </li>
            ))}
          </ul>
          </>
        )}

      </aside>
      )}

    </div>

  </div>

</BaseLayout>

<style>
  .detail-wrap {
    padding: 3rem 3rem 4rem;
  }

  .detail-header {
    max-width: 780px;
  }

  /* ── Two-column body ── */
  .detail-body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 0 3rem;
    align-items: start;
  }

  .detail-main {
    min-width: 0;
    max-width: 640px;
  }

  /* ── Sidebar ── */
  .detail-sidebar {
    border-left: 1px solid var(--rule);
    padding-left: 2rem;
    padding-top: 2.5rem;
  }

  .sidebar-map {
    overflow: hidden;
    border: 1px solid var(--rule);
    margin-bottom: 1.5rem;
  }

  .sidebar-map iframe {
    display: block;
    width: 100%;
    height: 180px;
  }

  .sidebar-label {
    display: block;
    font-family: var(--mono);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }

  .days-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .day {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--rule);
    font-family: var(--sans);
    font-size: var(--step-0);
  }

  .day:last-child { border-bottom: none; }

  .day-short {
    font-family: var(--mono);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    width: 2rem;
    flex-shrink: 0;
  }

  .day-full {
    font-family: var(--sans);
    font-size: var(--step-0);
    font-weight: 400;
  }

  .day--open .day-short,
  .day--open .day-full {
    color: var(--ink);
  }

  .day--open .day-short { color: var(--accent); }

  .day--closed .day-short,
  .day--closed .day-full {
    color: var(--rule-dark);
  }

  /* ── Header elements ── */
  .back {
    margin-bottom: 2rem;
  }

  .back a {
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back a:hover { color: var(--ink); }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }

  .dot { color: var(--rule-dark); }
  .pick { color: var(--accent); }

  .cuisine-link {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cuisine-link:hover { color: var(--accent); }

  .detail-name {
    font-family: var(--serif);
    font-size: clamp(var(--step-5), 6vw, var(--step-6));
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.6rem;
  }

  .detail-address {
    font-family: var(--sans);
    font-size: var(--step-0);
    font-weight: 400;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .photo-wrap {
    margin-top: 2rem;
  }

  .photo-wrap img {
    width: 100%;
    height: 460px;
    object-fit: cover;
    display: block;
  }

  .detail-rule {
    height: 1px;
    background: var(--rule);
    margin: 2.5rem 0;
  }

  .detail-desc {
    font-family: var(--sans);
    font-size: clamp(var(--step-2), 2vw, var(--step-3));
    font-weight: 400;
    line-height: 1.75;
    color: var(--ink-mid);
  }

  .detail-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .link-primary,
  .link-secondary {
    font-family: var(--serif);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.15s;
  }

  .link-primary {
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
  }

  .link-primary:hover { color: var(--accent); border-color: var(--accent); }

  .link-secondary { color: var(--ink-muted); }
  .link-secondary:hover { color: var(--ink); }

  /* ── Top dishes ── */
  .top-dishes {
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border-left: 3px solid var(--accent);
  }

  .top-dishes-label {
    display: block;
    font-family: var(--mono);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .top-dishes-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .top-dishes-list li {
    font-family: var(--serif);
    font-size: var(--step-2);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.4;
    padding-left: 1rem;
    position: relative;
  }

  .top-dishes-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--rule-dark);
    font-style: normal;
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .detail-wrap { padding: 2rem 1.5rem 3rem; }
    .detail-body { grid-template-columns: 1fr; }
    .detail-sidebar {
      border-left: none;
      border-top: 1px solid var(--rule);
      padding-left: 0;
      padding-top: 2rem;
      margin-top: 0;
    }
    .days-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .day {
      border-bottom: none;
      border: 1px solid var(--rule);
      padding: 0.3rem 0.6rem;
      gap: 0.35rem;
    }
    .day-full { display: none; }
    .day-short { width: auto; }
    .day--open { border-color: var(--ink); }
    .day--closed { opacity: 0.4; }
  }
</style>
